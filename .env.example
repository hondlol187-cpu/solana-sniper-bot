# Solana Sniper Bot Configuration
# ======================================
#
# ⚠️ CRITICAL SECURITY WARNINGS ⚠️
# 1. NEVER commit this file or share your PRIVATE_KEY
# 2. Use a DEDICATED BURNER WALLET with small amounts only
# 3. Test on DEVNET first before using real money on mainnet
# 4. You can lose 100% of funds used with this bot
# 5. Sniping is highly competitive and risky

# Solana RPC URL (use fast private RPC for real sniping)
RPC_URL=https://api.mainnet-beta.solana.com
# For devnet testing: https://api.devnet.solana.com

# Your wallet private key in base58 format (from Phantom export or solana-keygen)
# NEVER put a main wallet here!
PRIVATE_KEY=your_base58_private_key_here

# Jito tip in lamports (small amount for priority, e.g. 0.0001 SOL = 100000)
JITO_TIP=100000

# Buy settings
BUY_AMOUNT_SOL=0.05
SLIPPAGE_BPS=300          # 3% slippage (increase for volatile tokens)

# Target sell multiplier (example 2x take profit)
TARGET_MULTIPLIER=2.0

# Minimum liquidity filter (in SOL) - expand this in code
MIN_LIQUIDITY_SOL=10

# ======================================
# Web starter (Next.js) database config
# ======================================
DATABASE_URL="file:./db/custom.db"
