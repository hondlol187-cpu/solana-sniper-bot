# Safe default: nothing is signed or broadcast.
LIVE_TRADING=false

# Primary RPC plus optional fallbacks, separated by commas.
RPC_URL=https://api.mainnet-beta.solana.com
RPC_URLS=https://api.mainnet-beta.solana.com

# Dry-run only requires the public address.
WALLET_PUBLIC_KEY=your_public_wallet_address

# Required only when LIVE_TRADING=true.
# Use a new burner wallet with very little SOL.
PRIVATE_KEY=

# Token selected manually or supplied by a future monitor.
OUTPUT_MINT=token_mint_to_test_or_trade

BUY_AMOUNT_SOL=0.01
SLIPPAGE_BPS=150

MAX_PRICE_IMPACT_PCT=3
MAX_EXIT_PRICE_IMPACT_PCT=10
MAX_ROUND_TRIP_LOSS_PCT=15
MAX_PRIORITY_FEE_LAMPORTS=500000

TARGET_MULTIPLIER=2
STOP_LOSS_PCT=30
POLL_INTERVAL_SECONDS=3
MAX_HOLD_MINUTES=30

# Conservative default.
ALLOW_TOKEN_2022=false

JUPITER_API_URL=https://lite-api.jup.ag/swap/v1

# Position state persistence + RPC failover
POSITION_STATE_FILE=./sniper-position.json
OPERATION_RETRIES=4

EMERGENCY_EXIT_MAX_PRICE_IMPACT_PCT=50

PROCESS_LOCK_FILE=./sniper-bot.lock
EXIT_BALANCE_CHECK_ATTEMPTS=10

# Reject stale Jupiter quotes.
MAX_QUOTE_AGE_SECONDS=20

# Buy amount plus this much extra SOL may leave the wallet.
# Covers priority fee, network fee and token-account rent.
MAX_EXTRA_BUY_LAMPORTS=5000000

# Maximum SOL expense for token-to-SOL exits.
MAX_EXIT_FEE_LAMPORTS=5000000

# Keep false unless using a trusted self-hosted endpoint.
ALLOW_CUSTOM_JUPITER_API=false

# ======================================
# Web starter (Next.js) database config
# ======================================
DATABASE_URL="file:./db/custom.db"
