# Use a dedicated burner wallet only.
# Trading remains disabled until LIVE_TRADING=true.
LIVE_TRADING=false

RPC_URL=https://api.mainnet-beta.solana.com
PRIVATE_KEY=your_burner_wallet_base58_private_key

# Token mint selected by your monitor or entered manually.
OUTPUT_MINT=replace_with_token_mint

BUY_AMOUNT_SOL=0.01
SLIPPAGE_BPS=150
MAX_PRICE_IMPACT_PCT=3
MAX_ROUND_TRIP_LOSS_PCT=15

JUPITER_API_URL=https://lite-api.jup.ag/swap/v1

# ======================================
# Web starter (Next.js) database config
# ======================================
DATABASE_URL="file:./db/custom.db"
